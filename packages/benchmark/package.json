{
  "name": "@prd-gen/benchmark",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./calibration": {
      "import": "./dist/calibration/index.js",
      "types": "./dist/calibration/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.calibration.json",
    "clean": "rm -rf dist",
    "bench": "node dist/runner.js",
    "calibrate:gates": "node dist/calibration/calibration/calibrate-gates.js"
  },
  "dependencies": {
    "@prd-gen/core": "workspace:*",
    "@prd-gen/orchestration": "workspace:*",
    "@prd-gen/strategy": "workspace:*",
    "@prd-gen/validation": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.7.0"
  }
}
