node_modules
*.tsbuildinfo
.DS_Store
*.db

# Auto-generated by Claude session hooks at startup (git state snapshot)
.claude/session-cache.json
# Pending calibration observations — grows at runtime; resolved asynchronously
# by the dual-annotator procedure (Phase 4.1, Curie R2). Never commit.
packages/benchmark/calibration/data/pending-observations.jsonl
# Dropped claims log — INCONCLUSIVE verdicts from third reviewer (C-Curie-A4).
packages/benchmark/calibration/data/dropped-claims.jsonl
# Judge observation audit log — resolved observations for confusion matrix replay (C-Shannon-CONCERN-1).
packages/benchmark/calibration/data/judge-observation-log.jsonl
# Gate-blocked log — Phase 4.5 censoring mitigation; one row per gate violation.
packages/benchmark/calibration/data/gate-blocked-log.jsonl
# Phase 4.2 retry-observations audit log — append-only, never committed.
# source: retry-observations.ts:appendRetryObservationLog path specification.
packages/benchmark/calibration/data/retry-observation-log.jsonl

# Keep MCP server dist/ (needed for plugin execution) — except compiled
# test artifacts which are produced at build time but never executed from
# dist/ (vitest runs against the .ts sources directly).
packages/mcp-server/dist/__tests__/
# Other packages' dist/ are build artifacts
packages/core/dist
packages/validation/dist
packages/strategy/dist
packages/benchmark/dist
packages/orchestration/dist
packages/verification/dist
packages/meta-prompting/dist
packages/ecosystem-adapters/dist
packages/skill/dist
# Phase 4.5 per-gate XmR chart JSONs — produced by calibrate-gates.ts at
# runtime; never committed (the master gate-calibration-K100.json carries
# the calibrated values; the XmR per-gate files are intermediate).
packages/benchmark/calibration/data/gate-calibration-K100.xmr/
# Agent dispatch worktrees — ephemeral, never committed
.claude/worktrees/
